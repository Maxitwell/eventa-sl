rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Event banners uploaded by organizers
    match /events/{userId}/{allPaths=**} {
      // Anyone can view the uploaded images (used for Discover page, etc.)
      allow read: if true;
      
      // Only the authenticated organizer can upload/delete images in their own folder
      allow write: if request.auth != null 
                   && request.auth.uid == userId;
    }
    
    // Fallback: Default deny for any other path
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
