rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEventOrganizer(eventId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- EVENTS COLLECTION ---
    match /events/{eventId} {
      
      // Anyone can get a specific event if they have the ID (required for Gatekeepers to verify Door Pins)
      allow get: if true;
                     
      // Splitting list queries helps Firestore's static analyzer
      allow list: if resource.data.status == 'published';
      allow list: if request.auth != null && resource.data.organizerId == request.auth.uid;

      // Only authenticated users can create an event
      allow create: if request.auth != null 
                    && request.resource.data.organizerId == request.auth.uid 
                    && request.resource.data.price >= 0
                    && request.resource.data.totalCapacity >= 0
                    && request.resource.data.ticketsSold == 0;

      // Only the event creator can update their event
      // Allow atomic increments for ticketsSold during purchases
      allow update: if (request.auth != null && resource.data.organizerId == request.auth.uid) ||
                    // Allow ticket purchase transactions to increment ticketsSold (even for guests)
                    (request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['ticketsSold', 'totalCapacity']) &&
                     request.resource.data.ticketsSold > resource.data.ticketsSold);
                     
      // Only the event creator can delete their event
      allow delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }

    // --- TICKETS COLLECTION ---
    match /tickets/{ticketId} {

      // Strict ticket privacy: only owner or event organizer can read.
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) ||
                  isEventOrganizer(resource.data.eventId);

      // Ticket minting must happen server-side via Admin SDK.
      allow create: if false;

      // Prevent client-side check-in and status mutation.
      // Only allow guest-account linking by authenticated owner.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId'])
                    && resource.data.userId.matches('^guest_.*')
                    && request.resource.data.userId == request.auth.uid;
      
      // Tickets cannot be deleted by users
      allow delete: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
